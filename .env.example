# --- GitHub ---
# PAT with repo scope (needs pull_requests: write to post reviews).
GITHUB_TOKEN=ghp_xxx
# Shared secret you also set in the repo webhook settings. Leave empty only for local mocks.
WEBHOOK_SECRET=change-me

# --- LLM provider ---
# Preset: deepseek (default) | openai | claude | local.
# Sets sane base_url/model defaults; override them below if needed.
LLM_PROVIDER=deepseek
# API key for the provider (leave empty for a keyless local model).
LLM_API_KEY=sk-xxx
# Optional overrides — leave empty to use the provider's defaults:
#   deepseek → https://api.deepseek.com        / deepseek-chat
#   openai   → https://api.openai.com/v1       / gpt-4o-mini
#   claude   → https://api.anthropic.com       / claude-sonnet-5
#   local    → http://localhost:11434/v1       / qwen2.5-coder  (Ollama)
LLM_BASE_URL=
LLM_MODEL=
# Send response_format=json_object (OpenAI/DeepSeek: true; some local models: false).
# Empty = use the provider default.
LLM_JSON_MODE=

# --- Behaviour ---
# Review focus: android (default) | compose | kmp | свой из profiles.d/ |
# auto — оркестратор сам определит направление(я) PR и запустит нужные профили.
REVIEW_PROFILE=android
# Set to false to run the whole pipeline without posting back to GitHub (dry-run).
POST_REVIEWS=true
