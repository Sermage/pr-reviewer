# --- GitHub ---
# PAT with repo scope (needs pull_requests: write to post reviews).
GITHUB_TOKEN=ghp_xxx
# Shared secret you also set in the repo webhook settings. Leave empty only for local mocks.
WEBHOOK_SECRET=change-me

# --- DeepSeek (OpenAI-compatible) ---
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# --- Behaviour ---
# Review focus: android (default) | kmp. Add more in app/profiles.py.
REVIEW_PROFILE=android
# Set to false to run the whole pipeline without posting back to GitHub (dry-run).
POST_REVIEWS=true
